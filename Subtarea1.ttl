@base <urn:uc3m.es:miaa> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<#webPage> rdfs:subClassOf dcterms:BibliographicResource .

<#Entity> a rdfs:Class .

<#mentions> a rdf:Property ;
  	    rdfs:domain dcterms:BibliographicResource .


<#mentionsInstance> rdfs:subPropertyOf <#mentions> .

<#mentionsEntity> rdfs:subPropertyOf <#mentions> ;
		  rdfs:range <#Entity> .

# =============================================================================
# Subtarea 1: Ampliación del vocabulario RDF Schema
# Descripción: Definición de las subclases de Entity (Person, Location,
# Organization) y la propiedad literal para el nombre de la entidad.
# =============================================================================

# 1. Definir las 3 subclases de la clase Entity
<#Person> a rdfs:Class ;
    rdfs:subClassOf <#Entity> ;
    rdfs:label "Persona" .

<#Location> a rdfs:Class ;
    rdfs:subClassOf <#Entity> ;
    rdfs:label "Ubicación" .

<#Organization> a rdfs:Class ;
    rdfs:subClassOf <#Entity> ;
    rdfs:label "Organización" .

# 2. Definir una propiedad con valor literal para el nombre de la entidad
<#entityName> a rdf:Property ;
    rdfs:domain <#Entity> ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "El nombre legible de la entidad con nombre." .